---

---

<div class="flex items-center justify-center min-h-screen bg-gray-100 p-4">
    <div class="bg-white rounded-lg shadow-md p-8 max-w-md w-full">
        <div class="text-center mb-4">
            <h1 class="text-xl font-semibold text-gray-800">Unlock Features</h1>
            <p class="mt-2 text-gray-500">Connect your API key to access personalized features.</p>
        </div>

        <div class="space-y-4">
            <div class="border-l-2 border-blue-500 pl-4 py-2">
                <h3 class="text-sm font-medium text-gray-700">Why We Need Your API Key</h3>
                <p class="text-xs text-gray-500">Your key enables secure access to external services, unlocking advanced features like personalized content.</p>
            </div>

            <div class="border-l-2 border-green-500 pl-4 py-2">
                <h3 class="text-sm font-medium text-gray-700">Your Data is Safe</h3>
                <p class="text-xs text-gray-500">We store your API key locally, ensuring privacy and security. Our open-source code guarantees full transparency.</p>
            </div>
        </div>

        <form id="api-key-form" class="mt-6">
            <label for="api-key" class="block text-sm text-gray-700">API Key</label>
            <input
                type="text"
                id="api-key"
                name="apiKey"
                class="mt-2 w-full rounded-md border-gray-300 shadow-sm text-sm p-2"
                placeholder="Enter API Key"
                required
            >
            <p class="mt-2 text-xs text-gray-400">Don't have a key? <a href="https://example.com/api-key-instructions" class="text-blue-500">Get one here</a>.</p>

            <button
                type="submit"
                class="mt-4 w-full py-2 px-4 bg-blue-600 text-white rounded-md hover:bg-blue-700"
            >
                Save & Unlock
            </button>
        </form>

        <div id="status-message" class="mt-4 text-center text-xs text-gray-500"></div>
    </div>
</div>
