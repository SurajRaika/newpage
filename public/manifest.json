{
  "manifest_version": 3,
  "name": "Tab Tracker",
  "version": "1.1",
  "description": "Records tab visits, navigation and reloads to chrome.storage.local and shows them in a popup.",
  "permissions": [
    "tabs",
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab History"
  },
  "options_page": "options.html",
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}