---
// CommandPalette.astro
// Reusable Astro/Tailwind component — keep UI/UX identical to your original.
---







<style>
    /* Edit CommandPalette Section (Modal Overlay) specific styles for visibility transition */
    #edit-CommandPalette-section {
        transition: opacity 0.15s ease-out; /* Fast fade for overlay */
    }
    #edit-CommandPalette-section.show {
        opacity: 1;
        pointer-events: auto;
    }
    /* Modal inside edit CommandPalette section for slide effect */
    #edit-CommandPalette-section .edit-CommandPalette-modal {
        transform: translateY(-100%); /* Start completely off-screen top */
        transition: transform 0.15s ease-out; /* Fast slide */
    }
    #edit-CommandPalette-section.show .edit-CommandPalette-modal {
        transform: translateY(0); /* Slide into view */
    }
</style>





<!-- CommandPalette Context Menu (Right-click) -->
<div id="edit-CommandPalette-section" class="fixed inset-0 bg-[rgb(var(--color-primary-bg),0.5)] bg-opacity-30 flex justify-center items-start z-[10000] opacity-0 pointer-events-none ">
      <div class="edit-CommandPalette-modal bg-[rgb(var(--color-secondary-bg))] border border-[rgb(var(--color-border-color))] rounded-sm p-2 flex flex-col items-center gap-2 w-[90%] max-w-xl shadow-none mt-4  focus-within:shadow-md
                  dark:bg-[rgb(var(--color-secondary-bg))] dark:border-[rgb(var(--color-border-color))] ">
          <div class=" w-full flex flex-row items-center gap-2">

                  <label for="edit-CommandPalette-input" id="command-palette-label" class="text-[rgb(var(--color-text-secondary))] text-sm flex flex-col gap-1 flex-grow
                                      dark:text-[rgb(var(--color-text-secondary))]">
              <input type="text" id="edit-CommandPalette-input" placeholder="Edit your CommandPalette title" class="bg-[rgb(var(--color-primary-bg))] border border-[rgb(var(--color-border-color))] rounded-sm px-2 py-1.5  focus:outline-none text-[rgb(var(--color-text-primary))] text-base w-full box-border 
                                      dark:bg-[rgb(var(--color-primary-bg))] dark:border-[rgb(var(--color-border-color))] dark:text-[rgb(var(--color-text-primary))] ">
          </label>

          <div class="button-group flex flex-row gap-1 items-center ml-auto">
            <button id="edit-CommandPalette-delete-button" class="delete-button bg-[rgb(var(--color-border-color))] text-[rgb(var(--color-text-primary))] px-2.5 py-1.5 border-none rounded-sm cursor-pointer font-semibold text-xs transition-colors duration-200 hover:bg-red-500 hover:text-white
                                      dark:bg-[rgb(var(--color-border-color))] dark:text-[rgb(var(--color-text-primary))]">Enter</button>
          </div>
          </div>
          <div id="edit-CommandPalette-extra" class=" hidden w-full mt-2 bg-[rgb(var(--color-secondary-bg))] border border-[rgb(var(--color-border-color))] rounded-sm p-2  overflow-y-scroll max-h-[50vh] "></div>
          <div id="edit-CommandPalette-action-buttons" class="w-full flex justify-between gap-1 items-center ml-auto"></div>

      </div>
</div>






<script>
(function () {
  const SECTION_ID = 'edit-CommandPalette-section';
  const INPUT_ID = 'edit-CommandPalette-input';
  const BUTTON_ID = 'edit-CommandPalette-delete-button';
  const LABEL_ID = 'command-palette-label';

  const paletteSection = document.getElementById(SECTION_ID);
  let paletteInput = document.getElementById(INPUT_ID);
  const paletteButton = document.getElementById(BUTTON_ID);
  const paletteLabel = document.getElementById(LABEL_ID);
  const extraContainer = document.getElementById('edit-CommandPalette-extra');
  const actionButtonsContainer = document.getElementById('edit-CommandPalette-action-buttons');

  const defaultLabelHTML = paletteLabel ? paletteLabel.innerHTML : '';

  const availableCommands = [
      { name: 'toggle theme', action: () => { console.log('Toggling theme...'); } },
      { name: 'open settings', action: () => { console.log('Opening settings...'); } },
      { name: 'log out', action: () => { console.log('Logging out...'); } }
  ];

  // Internal state
  let resolvePromise = null;
  let rejectPromise = null;
  let currentOptions = {};
  let ignoreDocumentClick = false;
  let _inputRef = paletteInput;

  // Restore default label
  function restoreDefaultLabel() {
    if (!paletteLabel) return;
    paletteLabel.innerHTML = defaultLabelHTML;
    paletteInput = document.getElementById(INPUT_ID);
    _inputRef = paletteInput;
  }

  // --------- NEW: extra/content & buttons helpers ----------
function setExtraContent(htmlOrNode) {
  if (!extraContainer) return;
  // clear previous
  extraContainer.innerHTML = '';

  if (typeof htmlOrNode === 'string') {
    extraContainer.innerHTML = htmlOrNode;
  } else if (htmlOrNode instanceof Node) {
    extraContainer.appendChild(htmlOrNode);
  }

  // make sure it's visible
  extraContainer.classList.remove('hidden');

  // dispatch a small event so callers can react to insertion
  window.dispatchEvent(new CustomEvent('command-palette-extra-updated', { detail: { html: htmlOrNode } }));
}

  function clearExtraContent() {
    if (!extraContainer) return;
    extraContainer.innerHTML = '';
  }

  function setActionButtons(buttons = []) {
    // buttons: [{ id?, label, action:function(payload){}, closeOnClick?:true|false, className?:'' }]
    if (!actionButtonsContainer) return;
    actionButtonsContainer.innerHTML = '';
    buttons.forEach((b, idx) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = b.label || `Action ${idx+1}`;
      btn.className = b.className || 'bg-[rgb(var(--color-border-color))] text-[rgb(var(--color-text-primary))] px-2.5 py-1.5 border-none rounded-sm cursor-pointer font-semibold text-xs transition-colors duration-200 hover:bg-red-500 hover:text-white                                       dark:bg-[rgb(var(--color-border-color))] dark:text-[rgb(var(--color-text-primary))]';
      btn.addEventListener('click', (ev) => {
        try {
          const payload = {
            value: paletteInput && paletteInput.value ? paletteInput.value.trim() : '',
            source: currentOptions.source || null,
            options: currentOptions
          };
          if (typeof b.action === 'function') b.action(payload, ev);
        } catch (err) {
          console.error('Action button error', err);
        }
        if (b.closeOnClick !== false) {
          // default behavior: close palette
          hide();
          // If there is a pending reject/resolve, reject with reason 'action' if unresolved
          if (typeof rejectPromise === 'function') {
            rejectPromise({ reason: 'action', options: currentOptions });
            resolvePromise = null;
            rejectPromise = null;
          }
        }
      });
      actionButtonsContainer.appendChild(btn);
    });
  }

  function clearActionButtons() {
    if (!actionButtonsContainer) return;
    actionButtonsContainer.innerHTML = '';
  }

  // --------- show/hide/resolve API ----------
  function show(options = {}) {
    currentOptions = options || {};

    if (options.placeholder !== undefined && paletteInput) paletteInput.placeholder = options.placeholder;
    if (options.initialValue !== undefined && paletteInput) paletteInput.value = options.initialValue;
    else if (paletteInput) paletteInput.value = '';

    if (options.htmlContent !== undefined && options.htmlContent !== null && paletteLabel) {
      paletteLabel.innerHTML = options.htmlContent;
      const providedInput = paletteLabel.querySelector('input');
      if (!providedInput) {
        paletteLabel.insertAdjacentHTML('beforeend', `<input type="text" id="${INPUT_ID}" class="bg-[rgb(var(--color-primary-bg))] border border-[rgb(var(--color-border-color))] rounded-sm px-2 py-1.5 focus:outline-none text-[rgb(var(--color-text-primary))] text-base w-full box-border" />`);
      }
      paletteInput = document.getElementById(INPUT_ID);
      _inputRef = paletteInput;
    } else {
      if (options.resetToDefaultLabel) restoreDefaultLabel();
    }

    if (options.submitLabel && paletteButton) paletteButton.textContent = options.submitLabel;
    else if (paletteButton) paletteButton.textContent = 'Enter';

    // override availableCommands if provided
    if (Array.isArray(options.commands)) {
      availableCommands.length = 0;
      options.commands.forEach(c => availableCommands.push(c));
    }

    // if options.extraContentHtml provided at show time, set it
    if (options.extraContentHtml) setExtraContent(options.extraContentHtml);
    if (options.actionButtons) setActionButtons(options.actionButtons);

    // Show overlay/modal
    paletteSection.classList.add('show');

    ignoreDocumentClick = true;
    setTimeout(() => { ignoreDocumentClick = false; }, 0);

    setTimeout(() => {
      if (paletteInput) {
        paletteInput.focus();
        const val = paletteInput.value || '';
        try { paletteInput.setSelectionRange(val.length, val.length); } catch (e) {}
      }
    }, 10);

    window.dispatchEvent(new CustomEvent('command-palette-open', { detail: { options } }));

    // Return a Promise that resolves on submit or rejects on cancel
    return new Promise((resolve, reject) => {
      resolvePromise = resolve;
      rejectPromise = reject;
    });
  }

  function hide() {
    paletteSection.classList.remove('show');
    try { if (paletteInput) paletteInput.value = ''; } catch (e) {}
    // clear extra content & buttons only if asked (default: keep them)
    if (!currentOptions.preserveExtraOnClose) {
      clearExtraContent();
      clearActionButtons();
    }
    window.dispatchEvent(new CustomEvent('command-palette-close', { detail: { options: currentOptions } }));
  }

  // Allow external resolution/rejection if the caller wants to control promise lifecycle
  function resolve(payload) {
    if (typeof resolvePromise === 'function') {
      resolvePromise(payload);
      resolvePromise = null;
      rejectPromise = null;
    }
    hide();
  }
  function reject(payload) {
    if (typeof rejectPromise === 'function') {
      rejectPromise(payload);
      resolvePromise = null;
      rejectPromise = null;
    }
    hide();
  }

  // --------- submit/cancel handlers ----------
  function handleAction() {
    const value = paletteInput && paletteInput.value ? paletteInput.value.trim() : '';

    const foundCommand = availableCommands.find(cmd => (cmd.name || '').toLowerCase() === value.toLowerCase());
    if (foundCommand && typeof foundCommand.action === 'function') {
      try { foundCommand.action(); } catch (e) { console.error(e); }
    }

    const payload = {
      value,
      source: currentOptions.source || null,
      options: currentOptions
    };

    // If caller requested to keep palette open on Enter, dispatch a special event and DO NOT hide
    if (currentOptions.keepOpenOnSubmit) {
      window.dispatchEvent(new CustomEvent('command-palette-enter', { detail: payload }));
      // Optionally clear input if requested
      if (currentOptions.clearInputOnEnter) {
        if (paletteInput) paletteInput.value = '';
      }
      // Do NOT resolve/reject the promise here. Caller will call CommandPalette.resolve(...) when done.
      return;
    }

    // default behaviour: dispatch submit event and resolve promise and hide
    window.dispatchEvent(new CustomEvent('command-palette-submit', { detail: payload }));

    if (typeof resolvePromise === 'function') {
      resolvePromise(payload);
      resolvePromise = null;
      rejectPromise = null;
    }
    hide();
  }

  function handleCancel() {
    if (typeof rejectPromise === 'function') {
      rejectPromise({ reason: 'cancel', options: currentOptions });
      resolvePromise = null;
      rejectPromise = null;
    }
    hide();
  }

  function inputHandler(e) {
    const query = _inputRef && _inputRef.value ? _inputRef.value.trim().toLowerCase() : '';
    // console.log(`User is typing: ${query}`);
  }

  // --------- init listeners ----------
  function initListeners() {
    document.addEventListener('keydown', (e) => {
      if (e.ctrlKey && e.shiftKey && e.key === 'Q') {
        e.preventDefault();
        show({});
      } else if (e.key === 'Escape') {
        if (paletteSection.classList.contains('show')) {
          handleCancel();
        }
      }
    });

    document.addEventListener('input', (ev) => {
      const target = ev.target;
      const ourInput = document.getElementById(INPUT_ID);
      if (!ourInput) return;
      if (target === ourInput) {
        _inputRef = ourInput;
        inputHandler(ev);
      }
    });

    document.addEventListener('keydown', (ev) => {
      const ourInput = document.getElementById(INPUT_ID);
      if (!ourInput) return;
      if (ev.key === 'Enter' && document.activeElement === ourInput) {
        ev.preventDefault();
        handleAction();
      }
    });

    if (paletteButton) {
      paletteButton.addEventListener('click', (e) => {
        e.preventDefault();
        handleAction();
      });
    }

    // click outside modal to hide/cancel
    document.addEventListener('click', (e) => {
      if (ignoreDocumentClick) {
        ignoreDocumentClick = false;
        return;
      }

      const paletteModal = document.querySelector('#edit-CommandPalette-section .edit-CommandPalette-modal');
      if (paletteSection.classList.contains('show') && paletteModal && !paletteModal.contains(e.target)) {
        handleCancel();
      }
    });

    // listen to events from other components to set content/buttons
    window.addEventListener('command-palette-set-content', (ev) => {
      const html = ev.detail && ev.detail.html;
      setExtraContent(html);
    });
    window.addEventListener('command-palette-clear-content', () => clearExtraContent());

    window.addEventListener('command-palette-set-buttons', (ev) => {
      const buttons = ev.detail && ev.detail.buttons;
      setActionButtons(Array.isArray(buttons) ? buttons : []);
    });
    window.addEventListener('command-palette-clear-buttons', () => clearActionButtons());

    // listen for global open event
    window.addEventListener('open-command-palette', (ev) => {
      show(ev.detail || {});
    });
  }

  // Public API
  const API = {
    show,
    hide,
    resolve,
    reject,
    on: (eventName, cb) => window.addEventListener(eventName, cb),
    off: (eventName, cb) => window.removeEventListener(eventName, cb),
    openViaEvent: (options) => window.dispatchEvent(new CustomEvent('open-command-palette', { detail: options })),
    // convenience helpers to inject content / buttons programmatically
    setExtraContent,
    clearExtraContent,
    setActionButtons,
    clearActionButtons
  };

  if (!window.CommandPalette) window.CommandPalette = API;
  else Object.assign(window.CommandPalette, API);

  initListeners();
})();
</script>
